<section class="section">
  <div class="container">
    <h1>Admin Dashboard</h1>
    <p class="lead">Willkommen im Verwaltungsbereich von CoffeeArt Bremen.</p>

    <div class="admin-stats">
      <div class="stat-card">
        <h3><%= products.length %></h3>
        <p>Produkte</p>
      </div>
      <div class="stat-card">
        <h3><%= articles.length %></h3>
        <p>Blogartikel</p>
      </div>
    </div>

    <div class="admin-actions">
      <button class="btn btn-primary" onclick="alert('Produkt hinzufügen – Funktion folgt in der nächsten Version.')">Produkt hinzufügen</button>
      <button class="btn btn-primary" onclick="alert('Artikel hinzufügen – Funktion folgt in der nächsten Version.')">Artikel hinzufügen</button>
    </div>

    <h2>Produktübersicht</h2>
    <div class="admin-table-wrapper">
      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Kaffeesorte</th>
            <th>Herkunft</th>
            <th>Preis</th>
            <th>Bestand</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach(function(p) { %>
            <tr>
              <td><%= p.id %></td>
              <td><%= p.name %></td>
              <td><%= p.kaffeesorte %></td>
              <td><%= p.origin %></td>
              <td><%= p.price.toFixed(2).replace('.', ',') %> €</td>
              <td><%= p.orderInfo.stock %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <h2>Artikelübersicht</h2>
    <div class="admin-table-wrapper">
      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Titel</th>
            <th>Autor</th>
          </tr>
        </thead>
        <tbody>
          <% articles.forEach(function(a) { %>
            <tr>
              <td><%= a.id %></td>
              <td><%= a.title %></td>
              <td><%= a.author %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>
