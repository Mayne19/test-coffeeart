<section class="section">
  <div class="container">
    <h1>Coffee Finder</h1>
    <p class="lead">Finde deinen perfekten Kaffee. Beantworte ein paar Fragen und wir empfehlen dir einen unserer Röstungen.</p>

    <% if (typeof submitted !== 'undefined' && submitted && typeof recommendation !== 'undefined') { %>
      <div class="recommendation">
        <h2>Deine Empfehlung</h2>
        <div class="product-card recommendation-card">
          <img src="<%= recommendation.image %>" alt="<%= recommendation.name %>" class="product-card-image">
          <h3><%= recommendation.name %></h3>
          <p class="product-origin"><%= recommendation.origin %></p>
          <p class="product-taste"><%= recommendation.taste %> · Stärke <%= recommendation.strength %></p>
          <p class="product-price"><%= recommendation.price.toFixed(2).replace('.', ',') %> €</p>
          <a href="/shop/<%= recommendation.id %>" class="btn btn-primary">Zum Produkt</a>
        </div>
        <a href="/coffee-finder" class="btn btn-secondary">Erneut versuchen</a>
      </div>
    <% } %>

    <form class="coffee-finder-form" method="POST" action="/coffee-finder">
      <div class="finder-question">
        <h3>1. Wie erfahren bist du im Kaffeegenuss?</h3>
        <label><input type="radio" name="level" value="beginner" checked> Beginner – Ich trinke gerne Kaffee, kenne mich aber nicht so aus.</label>
        <label><input type="radio" name="level" value="expert"> Expert – Ich weiß genau, was ich will.</label>
      </div>

      <div class="finder-question">
        <h3>2. Welchen Geschmack bevorzugst du?</h3>
        <label><input type="radio" name="taste" value="Schokoladig" checked> Schokoladig</label>
        <label><input type="radio" name="taste" value="Fruchtig"> Fruchtig</label>
        <label><input type="radio" name="taste" value="Nussig"> Nussig</label>
        <label><input type="radio" name="taste" value="Blumig"> Blumig</label>
        <label><input type="radio" name="taste" value="Mild"> Mild</label>
        <label><input type="radio" name="taste" value="Karamellig"> Karamellig</label>
      </div>

      <div class="finder-question">
        <h3>3. Welche Zubereitungsart nutzt du hauptsächlich?</h3>
        <label><input type="radio" name="method" value="siebtraeger" checked> Siebträger</label>
        <label><input type="radio" name="method" value="filter"> Filter / Chemex</label>
        <label><input type="radio" name="method" value="frenchpress"> French Press</label>
        <label><input type="radio" name="method" value="vollautomat"> Vollautomat</label>
        <label><input type="radio" name="method" value="aeropress"> Aeropress</label>
      </div>

      <div class="finder-question">
        <h3>4. Wie stark darf der Kaffee sein?</h3>
        <label><input type="radio" name="strength" value="mild" checked> Mild (1–2)</label>
        <label><input type="radio" name="strength" value="mittel"> Mittel (3)</label>
        <label><input type="radio" name="strength" value="stark"> Stark (4–5)</label>
      </div>

      <div class="finder-question">
        <h3>5. Welche Kaffeesorte interessiert dich?</h3>
        <label><input type="radio" name="type" value="Espresso" checked> Espresso</label>
        <label><input type="radio" name="type" value="Filterkaffee"> Filterkaffee</label>
        <label><input type="radio" name="type" value="Caffe Crema"> Caffe Crema</label>
      </div>

      <button type="submit" class="btn btn-primary">Empfehlung erhalten</button>
    </form>
  </div>
</section>
