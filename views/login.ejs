<section class="section">
  <div class="container">
    <h1>Login</h1>
    <p class="lead">Melde dich mit deiner E-Mail und deinem Passwort an.</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form class="login-form" method="POST" action="/login">
      <div class="form-group">
        <label for="email">E-Mail</label>
        <input type="email" id="email" name="email" placeholder="z. B. max.muster@example.com" required>
      </div>
      <div class="form-group">
        <label for="password">Passwort</label>
        <input type="password" id="password" name="password" placeholder="Dein Passwort" required>
      </div>
      <button type="submit" class="btn btn-primary">Anmelden</button>
    </form>

    <div class="demo-hint">
      <p><strong>Demo-Zugänge:</strong> Die Zugangsdaten sind in <code>data/users.json</code> hinterlegt und nur für die Demonstration gedacht.</p>
    </div>
  </div>
</section>
