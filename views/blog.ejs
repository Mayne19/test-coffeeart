<section class="section">
  <div class="container">
    <h1>Blog</h1>
    <p class="lead">Tauchen Sie ein in die Welt des Kaffees – mit Geschichten aus unserer Rösterei.</p>

    <div class="blog-list">
      <% articles.forEach(function(article) { %>
        <article class="blog-card-full">
          <h2><%= article.title %></h2>
          <p class="article-meta">Von <%= article.author %></p>
          <p><%= article.excerpt %></p>
          <p class="article-coffee-info"><strong>Kaffee-Info:</strong> <%= article.coffeeInfo %></p>
          <a href="/blog/<%= article.id %>" class="btn btn-small">Weiterlesen</a>
        </article>
      <% }) %>
    </div>
  </div>
</section>
