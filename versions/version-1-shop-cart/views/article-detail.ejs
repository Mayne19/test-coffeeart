<section class="section">
  <div class="container">
    <a href="/blog" class="back-link"><i class="hgi-stroke hgi-arrow-left-02" aria-hidden="true"></i><span>Zurück zum Blog</span></a>
    <article class="article-detail">
      <h1><%= article.title %></h1>
      <p class="article-meta">Von <%= article.author %></p>

      <div class="article-content">
        <p><%= article.content %></p>
      </div>

      <div class="article-coffee-info">
        <h3>Dazugehörige Kaffee-Informationen</h3>
        <p><%= article.coffeeInfo %></p>
      </div>
    </article>
  </div>
</section>
