<section class="section product-detail-section">
  <div class="container product-detail-container">
    <a href="/shop" class="back-link"><i class="hgi-stroke hgi-arrow-left-02" aria-hidden="true"></i><span>Zurück zum Shop</span></a>

    <div class="product-detail product-detail-commerce">
      <div class="product-gallery">
        <div class="product-detail-image">
          <img src="<%= product.image %>" alt="<%= product.name %>">
        </div>

        <div class="product-thumbnails" aria-label="Produktbilder">
          <button class="product-thumbnail is-active" type="button" aria-label="Produktbild anzeigen">
            <img src="<%= product.image %>" alt="">
          </button>
          <button class="product-thumbnail" type="button" aria-label="Kaffeepflanze anzeigen">
            <img src="https://images.unsplash.com/photo-1514432324607-a09d9b4aefdd?w=260&h=180&fit=crop" alt="">
          </button>
          <button class="product-thumbnail" type="button" aria-label="Kaffeebohnen anzeigen">
            <img src="https://images.unsplash.com/photo-1447933601403-0c6688de566e?w=260&h=180&fit=crop" alt="">
          </button>
        </div>
      </div>

      <div class="product-detail-info">
        <p class="product-origin product-detail-origin"><%= product.origin.toUpperCase() %></p>
        <h1><%= product.name %></h1>
        <p class="product-tagline"><%= product.taste %>. Vollmundig. Bewusst genießen.</p>
        <p class="product-description">
          <%= product.name %> verbindet <%= product.taste.toLowerCase() %>e Noten mit einer sorgfältigen Trommelröstung.
          Die Bohnen aus <%= product.origin %> eignen sich für bewussten Kaffeegenuss zu Hause.
        </p>

        <h2>Produktdetails</h2>
        <table class="product-table">
          <tr>
            <td>Herkunft</td>
            <td><%= product.origin %></td>
          </tr>
          <tr>
            <td>Geschmack</td>
            <td><%= product.taste %></td>
          </tr>
          <tr>
            <td>Gewicht</td>
            <td><%= product.weight %>g</td>
          </tr>
          <tr>
            <td>Kaffeesorte</td>
            <td><%= product.kaffeesorte %></td>
          </tr>
        </table>

        <div class="coffee-profile">
          <h2>Kaffeeprofil</h2>
          <% coffeeProfile.slice(0, 3).forEach(function(item) { %>
            <div class="profile-row">
              <span class="profile-icon" aria-hidden="true">
                <% if (item.label === 'Stärke') { %><i class="hgi-stroke hgi-dashboard-speed-01"></i><% } else if (item.label === 'Röstung') { %><i class="hgi-stroke hgi-fire"></i><% } else if (item.label === 'Säure') { %><i class="hgi-stroke hgi-droplet"></i><% } else { %><i class="hgi-stroke hgi-coffee-beans"></i><% } %>
              </span>
              <span class="profile-label"><%= item.label %></span>
              <div class="profile-track" aria-label="<%= item.label %>: <%= item.value %> von 5">
                <span class="profile-fill" style="width: <%= item.value * 20 %>%"></span>
              </div>
              <span class="profile-value"><%= item.value %>/5</span>
            </div>
          <% }) %>
        </div>

        <h2>Röstprofil</h2>
        <table class="product-table">
          <tr>
            <td>Temperatur</td>
            <td><%= product.roastProfile.temperature %></td>
          </tr>
          <tr>
            <td>Dauer</td>
            <td><%= product.roastProfile.duration %></td>
          </tr>
          <tr>
            <td>Röstgrad</td>
            <td><%= product.roastProfile.level %></td>
          </tr>
        </table>

        <div class="preparation-note">
          <h2>Zubereitungstipps</h2>
          <p><%= product.preparationTips %></p>
        </div>
      </div>

      <aside class="purchase-box" aria-label="Kaufbox">
        <p class="purchase-price"><%= product.price.toFixed(2).replace('.', ',') %> €</p>
        <p class="purchase-tax">inkl. MwSt., zzgl. Versand</p>

        <% if (product.orderInfo.available) { %>
          <p class="product-available"><i class="hgi-stroke hgi-checkmark-circle-02" aria-hidden="true"></i><span>Auf Lager (<%= product.orderInfo.stock %> verfügbar)</span></p>
        <% } else { %>
          <p class="product-unavailable">Aktuell nicht verfügbar</p>
        <% } %>

        <div class="delivery-info">
          <strong><i class="hgi-stroke hgi-truck-delivery" aria-hidden="true"></i><span>Lieferinformationen</span></strong>
          <span>Standardversand innerhalb von 2-4 Werktagen.</span>
          <span>Versandkosten: 4,90 €</span>
        </div>

        <% if (product.orderInfo.available) { %>
          <div class="add-to-cart <%= typeof cartCount !== 'undefined' && cartCount > 0 ? 'is-added' : '' %>">
            <label for="quantity">Menge</label>
            <div class="purchase-actions">
              <div class="quantity-control" aria-label="Menge auswählen">
                <button type="button" class="quantity-step" data-step="-1" aria-label="Menge verringern"><i class="hgi-stroke hgi-minus-sign" aria-hidden="true"></i></button>
                <input type="number" id="quantity" value="1" min="1" max="<%= product.orderInfo.stock %>" class="qty-input">
                <button type="button" class="quantity-step" data-step="1" aria-label="Menge erhöhen"><i class="hgi-stroke hgi-plus-sign" aria-hidden="true"></i></button>
              </div>
              <button class="btn btn-primary add-to-cart-btn product-add-btn" data-id="<%= product.id %>"><span>In den Warenkorb</span></button>
            </div>
            <p class="quantity-notice" aria-live="polite"></p>
            <a href="/warenkorb" class="btn btn-outline cart-link-after-add">Zum Warenkorb</a>
          </div>
        <% } %>

        <p class="secure-payment"><i class="hgi-stroke hgi-shield-01" aria-hidden="true"></i><span>Sichere Zahlung garantiert</span></p>
      </aside>
    </div>
  </div>
</section>
