<section class="section">
  <div class="container">
    <% if (typeof submitted !== 'undefined' && submitted) { %>
      <div class="checkout-success">
        <h1>Bestellung eingegangen</h1>
        <p>Vielen Dank, <strong><%= vorname %> <%= nachname %></strong>! Deine Bestellung wurde aufgenommen.</p>
        <p>Dies ist eine Demo - die Bestellung wurde nicht an ein echtes System übertragen.</p>
        <a href="/shop" class="btn btn-primary"><i class="hgi-stroke hgi-shopping-bag-03" aria-hidden="true"></i><span>Weiter einkaufen</span></a>
      </div>
    <% } else if (!cart || cart.length === 0) { %>
      <div class="empty-state">
        <h1>Warenkorb ist leer</h1>
        <p class="lead">Dein Warenkorb enthält keine Produkte. Gehe zum Shop, um Kaffee hinzuzufügen.</p>
        <a href="/shop" class="btn btn-primary"><i class="hgi-stroke hgi-shopping-bag-03" aria-hidden="true"></i><span>Zum Shop</span></a>
      </div>
    <% } else { %>
      <h1>Warenkorb</h1>
      <p class="lead">Überprüfe deine Produkte und schließe die Bestellung ab.</p>

      <% let subtotal = 0 %>
      <% const cartProducts = cart.map(function(item) {
        const product = products.find(pr => pr.id === item.productId);
        if (!product) return null;
        const lineTotal = product.price * item.quantity;
        subtotal += lineTotal;
        return { item, product, lineTotal };
      }).filter(Boolean) %>
      <% const shipping = subtotal > 0 ? 4.90 : 0 %>
      <% const total = subtotal + shipping %>
      <% const vat = total * 0.19 / 1.19 %>

      <div class="cart-page">
        <div class="cart-items-panel">
          <h2>Produkte im Warenkorb</h2>
          <div class="cart-items">
            <% cartProducts.forEach(function(entry) { %>
              <article class="cart-item">
                <img src="<%= entry.product.image %>" alt="<%= entry.product.name %>" class="cart-item-image">
                <div class="cart-item-info">
                  <h3><%= entry.product.name %></h3>
                  <p><%= entry.product.origin %> · <%= entry.product.taste %></p>
                  <p><%= entry.product.kaffeesorte %> · <%= entry.product.weight %>g</p>
                  <form method="POST" action="/cart/remove/<%= entry.product.id %>">
                    <button type="submit" class="remove-cart-btn"><i class="hgi-stroke hgi-shopping-cart-remove-02" aria-hidden="true"></i><span>Entfernen</span></button>
                  </form>
                </div>
                <div class="cart-item-meta">
                  <span><%= entry.product.price.toFixed(2).replace('.', ',') %> €</span>
                  <span>Menge: <%= entry.item.quantity %></span>
                  <strong><%= entry.lineTotal.toFixed(2).replace('.', ',') %> €</strong>
                </div>
              </article>
            <% }) %>
          </div>
        </div>

        <aside class="order-summary">
          <h2>Bestellübersicht</h2>
          <div class="summary-row">
            <span>Zwischensumme</span>
            <strong><%= subtotal.toFixed(2).replace('.', ',') %> €</strong>
          </div>
          <div class="summary-row">
            <span>Versandkosten</span>
            <strong><%= shipping.toFixed(2).replace('.', ',') %> €</strong>
          </div>
          <div class="summary-row">
            <span>MwSt.</span>
            <strong><%= vat.toFixed(2).replace('.', ',') %> €</strong>
          </div>
          <div class="summary-row summary-total">
            <span>Gesamtpreis</span>
            <strong><%= total.toFixed(2).replace('.', ',') %> €</strong>
          </div>

          <form class="checkout-form" method="POST" action="/warenkorb">
            <h2>Lieferdaten</h2>
            <div class="form-row">
              <div class="form-group">
                <label for="vorname">Vorname *</label>
                <input type="text" id="vorname" name="vorname" required>
              </div>
              <div class="form-group">
                <label for="nachname">Nachname *</label>
                <input type="text" id="nachname" name="nachname" required>
              </div>
            </div>
            <div class="form-group">
              <label for="adresse">Adresse *</label>
              <input type="text" id="adresse" name="adresse" placeholder="Straße, Hausnummer, PLZ, Ort" required>
            </div>
            <div class="form-group">
              <label for="lieferanschrift">Lieferanschrift</label>
              <input type="text" id="lieferanschrift" name="lieferanschrift" placeholder="Abweichende Lieferadresse (optional)">
            </div>
            <button type="submit" class="btn btn-primary btn-full"><i class="hgi-stroke hgi-payment-success-02" aria-hidden="true"></i><span>Bestellung abschließen</span></button>
          </form>
        </aside>
      </div>
    <% } %>
  </div>
</section>
