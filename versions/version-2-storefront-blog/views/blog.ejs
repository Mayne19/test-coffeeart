<section class="section blog-section">
  <div class="container">
    <% const activeCategory = typeof selectedCategory !== 'undefined' ? selectedCategory : "" %>
    <% const blogCategories = typeof categories !== 'undefined' ? categories : [...new Set(articles.map((article) => article.category).filter(Boolean))].map((category) => ({ label: category, slug: category })) %>
    <h1>Blog</h1>
    <p class="lead">Einblicke, Tipps und Geschichten aus unserer Rösterei.</p>

    <nav class="blog-filters" aria-label="Blog Kategorien">
      <a href="/blog" class="<%= !activeCategory ? 'is-active' : '' %>">Alle</a>
      <% blogCategories.forEach(function(category) { %>
        <% const categoryLabel = category.label || category %>
        <% const categorySlug = category.slug || category %>
        <a href="/blog?category=<%= encodeURIComponent(categorySlug) %>" class="<%= activeCategory === categorySlug ? 'is-active' : '' %>"><%= categoryLabel %></a>
      <% }) %>
    </nav>

    <div class="blog-list">
      <% articles.forEach(function(article) { %>
        <article class="blog-card-full">
          <a href="/blog/<%= article.id %>" class="blog-card-image-link">
            <img src="<%= article.image %>" alt="<%= article.title %>" class="blog-card-image">
          </a>
          <div class="blog-card-body">
            <p class="article-meta"><%= article.date %> <span>·</span> <%= article.category %></p>
            <h2><a href="/blog/<%= article.id %>"><%= article.title %></a></h2>
            <p class="blog-excerpt"><%= article.excerpt %></p>
            <a href="/blog/<%= article.id %>" class="blog-read-link">Weiterlesen →</a>
          </div>
        </article>
      <% }) %>
    </div>

    <% if (articles.length === 0) { %>
      <div class="empty-state blog-empty-state">
        <p>Keine Artikel in dieser Kategorie gefunden.</p>
        <a href="/blog" class="blog-read-link">Alle Artikel anzeigen →</a>
      </div>
    <% } %>
  </div>
</section>
